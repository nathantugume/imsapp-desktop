<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.BrandEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Brand"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Save_Click"
    DefaultButton="Primary">

    <StackPanel Padding="0,8,0,0">
        <TextBox x:Name="BrandNameBox" Header="Brand Name" PlaceholderText="Enter brand name" Margin="0,0,0,8" />
        <ComboBox x:Name="StatusCombo" Header="Status" SelectedIndex="0" Margin="0,0,0,0">
            <x:String>Active</x:String>
            <x:String>Inactive</x:String>
        </ComboBox>
    </StackPanel>
</ContentDialog>
