<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.ProductEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Product"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Save_Click"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="500">
        <StackPanel Padding="0,8,0,0">
            <TextBox x:Name="ProductNameBox" Header="Product Name" PlaceholderText="Enter product name" Margin="0,0,0,8" />
            <ComboBox x:Name="CategoryCombo" Header="Category" DisplayMemberPath="CategoryName" Margin="0,0,0,8" />
            <ComboBox x:Name="BrandCombo" Header="Brand" DisplayMemberPath="BrandName" Margin="0,0,0,8" />
            <ComboBox x:Name="SupplierCombo" Header="Supplier" DisplayMemberPath="SupplierName" Margin="0,0,0,8" />
            <NumberBox x:Name="StockBox" Header="Stock" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
            <ComboBox x:Name="SaleUnitCombo" Header="Sale Unit" Margin="0,0,0,8">
                <x:String>pieces</x:String>
                <x:String>items</x:String>
                <x:String>bags</x:String>
                <x:String>bottles</x:String>
                <x:String>cartons</x:String>
                <x:String>boxes</x:String>
                <x:String>kgs</x:String>
                <x:String>litres</x:String>
                <x:String>meters</x:String>
            </ComboBox>
            <ComboBox x:Name="PurchaseUnitCombo" Header="Purchase Unit (optional - for bulk buying)" Margin="0,0,0,8">
                <x:String>Same as sale unit</x:String>
                <x:String>carton</x:String>
                <x:String>crate</x:String>
                <x:String>box</x:String>
                <x:String>case</x:String>
                <x:String>pack</x:String>
                <x:String>dozen</x:String>
                <x:String>bundle</x:String>
                <x:String>bale</x:String>
                <x:String>sack</x:String>
                <x:String>bag</x:String>
            </ComboBox>
            <NumberBox x:Name="ConversionFactorBox" Header="Conversion Factor (pieces per pack)" Value="1" Minimum="1" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
            <NumberBox x:Name="PriceBox" Header="Retail Price" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
            <NumberBox x:Name="WholesalePriceBox" Header="Wholesale Price (optional)" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
            <NumberBox x:Name="BuyingPriceBox" Header="Buying Price" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
            <DatePicker x:Name="ExpiryDatePicker" Header="Expiry Date (optional)" Margin="0,0,0,8" />
            <TextBox x:Name="DescriptionBox" Header="Description" PlaceholderText="Product description" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8" />
            <ComboBox x:Name="StatusCombo" Header="Status" SelectedIndex="0" Margin="0,0,0,8">
                <x:String>Active</x:String>
                <x:String>Inactive</x:String>
            </ComboBox>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
