<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="imsapp_desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:imsapp_desktop"
    xmlns:conv="using:imsapp_desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <conv:CurrencyFormatConverter x:Key="CurrencyFormat" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
            <conv:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True" />

            <!-- Modern card style with subtle elevation -->
            <Style x:Key="StatCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Margin" Value="0,0,12,12" />
            </Style>

            <!-- Page title style -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Section header style -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="Margin" Value="0,24,0,12" />
            </Style>

            <!-- List item container style -->
            <Style x:Key="ListItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
