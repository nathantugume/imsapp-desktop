<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.CustomerPaymentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:CustomerPaymentsViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Customer Payments" Style="{StaticResource PageTitleStyle}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
            <Button Content="Record Payment" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" VerticalAlignment="Center" Click="RecordPayment_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Export Outstanding" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="CSV" Click="ExportOutstandingCsv_Click" />
                        <MenuFlyoutItem Text="Excel" Click="ExportOutstandingExcel_Click" />
                        <MenuFlyoutItem Text="PDF" Click="ExportOutstandingPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <Button Content="Export History" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="CSV" Click="ExportHistoryCsv_Click" />
                        <MenuFlyoutItem Text="Excel" Click="ExportHistoryExcel_Click" />
                        <MenuFlyoutItem Text="PDF" Click="ExportHistoryPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Outstanding Orders (due &gt; 0)" Style="{StaticResource SectionHeaderStyle}" />
        <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,0,0,24">
            <controls:DataGrid x:Name="OutstandingGrid"
                              ItemsSource="{x:Bind ViewModel.OutstandingOrders, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="OutstandingGrid_SelectionChanged"
                              MaxHeight="250"
                              HeadersVisibility="Column">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNo}" Width="80" />
                    <controls:DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding NetTotalFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Paid" Binding="{Binding PaidFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Due" Binding="{Binding DueFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Date" Binding="{Binding OrderDate}" Width="100" />
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>

        <TextBlock Grid.Row="4" Text="Recent Payment History" Style="{StaticResource SectionHeaderStyle}" />
        <Border Grid.Row="5" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,-12,0,0">
            <controls:DataGrid x:Name="HistoryGrid"
                              ItemsSource="{x:Bind ViewModel.PaymentHistory, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <controls:DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNo}" Width="80" />
                    <controls:DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                    <controls:DataGridTextColumn Header="Amount" Binding="{Binding AmountFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="100" />
                    <controls:DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="140" />
                    <controls:DataGridTextColumn Header="By" Binding="{Binding CreatedByName}" Width="120" />
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>
    </Grid>
</Page>
