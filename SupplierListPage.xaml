<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.SupplierListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:SupplierListViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Suppliers" Style="{StaticResource PageTitleStyle}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
            <Button Content="Add Supplier" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" VerticalAlignment="Center" Click="AddSupplier_Click" />
            <Button Content="Edit" Margin="8,0,0,0" VerticalAlignment="Center" Click="EditSupplier_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Delete" Margin="8,0,0,0" VerticalAlignment="Center" Click="DeleteSupplier_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Export" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Export CSV" Click="ExportCsv_Click" />
                        <MenuFlyoutItem Text="Export Excel" Click="ExportExcel_Click" />
                        <MenuFlyoutItem Text="Export PDF" Click="ExportPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0">
            <controls:DataGrid x:Name="SupplierGrid"
                              ItemsSource="{x:Bind ViewModel.Suppliers, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="SupplierGrid_SelectionChanged"
                              DoubleTapped="SupplierGrid_DoubleTapped"
                              HeadersVisibility="Column">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="ID" Binding="{Binding SupplierId}" Width="70" />
                    <controls:DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*" />
                    <controls:DataGridTextColumn Header="Contact" Binding="{Binding ContactPerson}" Width="140" />
                    <controls:DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120" />
                    <controls:DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" />
                    <controls:DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90" />
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>
    </Grid>
</Page>
