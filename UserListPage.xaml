<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.UserListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:UserListViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="User Management" Style="{StaticResource PageTitleStyle}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
            <Button Content="Add User" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" VerticalAlignment="Center" Click="AddUser_Click" />
            <Button Content="Edit" Margin="8,0,0,0" VerticalAlignment="Center" Click="EditUser_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Delete" Margin="8,0,0,0" VerticalAlignment="Center" Click="DeleteUser_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Export" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Export CSV" Click="ExportCsv_Click" />
                        <MenuFlyoutItem Text="Export Excel" Click="ExportExcel_Click" />
                        <MenuFlyoutItem Text="Export PDF" Click="ExportPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0">
            <controls:DataGrid x:Name="UserGrid"
                              ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="UserGrid_SelectionChanged"
                              DoubleTapped="UserGrid_DoubleTapped"
                              HeadersVisibility="Column">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <controls:DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <controls:DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200" />
                    <controls:DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="80" />
                    <controls:DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="120" />
                    <controls:DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90" />
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>
    </Grid>
</Page>
