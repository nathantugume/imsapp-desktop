<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.CreateOrderDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Create Order"
    PrimaryButtonText="Create Order"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="CreateOrderDialog_PrimaryButtonClick">

    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid MinWidth="520" Padding="20,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Customer & Order Info -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBox x:Name="CustomerName" Header="Customer Name" PlaceholderText="Enter customer name" />
                    <TextBox x:Name="Address" Header="Address" PlaceholderText="Enter address" Text="In-store" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="8">
                    <DatePicker x:Name="OrderDate" Header="Order Date" />
                    <ComboBox x:Name="PaymentMethod" Header="Payment Method" SelectedIndex="0">
                        <x:String>Cash</x:String>
                        <x:String>Card</x:String>
                        <x:String>Mobile Money</x:String>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Add Items -->
            <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add Items" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="ProductCombo" Header="Product" Width="280" DisplayMemberPath="ProductName" />
                        <NumberBox x:Name="QtyBox" Header="Qty" Value="1" Minimum="1" SpinButtonPlacementMode="Inline" Width="90" />
                        <Button Content="Add" Click="AddItem_Click" VerticalAlignment="Bottom" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Items List -->
            <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Order Items" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ListView x:Name="ItemsList" Height="160" SelectionMode="None" Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6" Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="2" Content="Wholesale" IsChecked="{Binding UseWholesale, Mode=TwoWay}" VerticalAlignment="Center" Checked="PriceMode_Changed" Unchecked="PriceMode_Changed" Visibility="{Binding HasWholesaleOption, Converter={StaticResource BoolToVisible}}" />
                                    <TextBlock Grid.Column="3" Text="{Binding LineTotalFormatted}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="{Binding PriceModeLabel}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10" />
                                    <Button Grid.Column="5" Content="✕" Click="RemoveItem_Click" Tag="{Binding}" FontSize="12" Padding="8,4" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Totals -->
            <StackPanel Grid.Row="3" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <NumberBox x:Name="DiscountBox" Header="Discount" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Width="120" ValueChanged="Totals_ValueChanged" />
                    <NumberBox x:Name="PaidBox" Header="Amount Paid" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Width="180" ValueChanged="Totals_ValueChanged" />
                </StackPanel>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="16" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sub Total :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="SubTotalText" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="GST (18%) :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="GstText" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Discount :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="DiscountText" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Net Total :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                        <TextBlock x:Name="NetTotalText" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="Bold" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Paid :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="PaidText" Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Due :" VerticalAlignment="Center" Margin="0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="DueText" Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="0,4" HorizontalAlignment="Right" FontWeight="SemiBold" />
                    </Grid>
                </Border>
                <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
