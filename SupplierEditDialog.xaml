<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.SupplierEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Supplier"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Save_Click"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="450">
        <StackPanel Padding="0,8,0,0">
            <TextBox x:Name="SupplierNameBox" Header="Supplier Name" PlaceholderText="Enter supplier name" Margin="0,0,0,8" />
            <TextBox x:Name="ContactPersonBox" Header="Contact Person (optional)" PlaceholderText="Contact name" Margin="0,0,0,8" />
            <TextBox x:Name="PhoneBox" Header="Phone (optional)" PlaceholderText="Phone number" Margin="0,0,0,8" />
            <TextBox x:Name="EmailBox" Header="Email (optional)" PlaceholderText="Email address" Margin="0,0,0,8" />
            <TextBox x:Name="AddressBox" Header="Address (optional)" PlaceholderText="Address" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8" />
            <ComboBox x:Name="StatusCombo" Header="Status" SelectedIndex="0" Margin="0,0,0,0">
                <x:String>Active</x:String>
                <x:String>Inactive</x:String>
            </ComboBox>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
