<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.ProductListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:ProductListViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Products" Style="{StaticResource PageTitleStyle}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
            <Button Content="Add Product" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" VerticalAlignment="Center" Click="AddProduct_Click" />
            <Button Content="Add Stock" Margin="8,0,0,0" VerticalAlignment="Center" Click="AddStock_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="View" Margin="8,0,0,0" VerticalAlignment="Center" Click="ViewProduct_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Edit" Margin="8,0,0,0" VerticalAlignment="Center" Click="EditProduct_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Delete" Margin="8,0,0,0" VerticalAlignment="Center" Click="DeleteProduct_Click" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            <Button Content="Export" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Export CSV" Click="ExportCsv_Click" />
                        <MenuFlyoutItem Text="Export Excel" Click="ExportExcel_Click" />
                        <MenuFlyoutItem Text="Export PDF" Click="ExportPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <Button x:Name="ColumnsButton" Content="Columns" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <Flyout x:Name="ColumnsFlyout" Placement="Bottom">
                        <StackPanel Padding="12" MinWidth="140">
                            <TextBlock Text="Show columns:" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox x:Name="ColId" Content="ID" Tag="ID" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColProduct" Content="Product" Tag="Product" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColCategory" Content="Category" Tag="Category" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColBrand" Content="Brand" Tag="Brand" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColSupplier" Content="Supplier" Tag="Supplier" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColStock" Content="Stock" Tag="Stock" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColUnit" Content="Unit" Tag="Unit" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColBuying" Content="Buying" Tag="Buying" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColRetail" Content="Retail" Tag="Retail" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColWholesale" Content="Wholesale" Tag="Wholesale" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                            <CheckBox x:Name="ColStatus" Content="Status" Tag="Status" IsChecked="True" Checked="ColumnToggle_Changed" Unchecked="ColumnToggle_Changed" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
            <ComboBox x:Name="FilterCategory" Header="Category" Width="180" Margin="0,0,12,0"
                      ItemsSource="{x:Bind ViewModel.Categories}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategoryFilter, Mode=TwoWay}"
                      DisplayMemberPath="CategoryName" />
            <ComboBox x:Name="FilterBrand" Header="Brand" Width="180" Margin="0,0,12,0"
                      ItemsSource="{x:Bind ViewModel.Brands}"
                      SelectedItem="{x:Bind ViewModel.SelectedBrandFilter, Mode=TwoWay}"
                      DisplayMemberPath="BrandName" />
            <ComboBox x:Name="FilterSupplier" Header="Supplier" Width="180" Margin="0,0,12,0"
                      ItemsSource="{x:Bind ViewModel.Suppliers}"
                      SelectedItem="{x:Bind ViewModel.SelectedSupplierFilter, Mode=TwoWay}"
                      DisplayMemberPath="SupplierName" />
            <ComboBox x:Name="FilterStatus" Header="Status" Width="120" Margin="0,0,12,0"
                      SelectedItem="{x:Bind ViewModel.SelectedStatusFilter, Mode=TwoWay}">
                <x:String>All</x:String>
                <x:String>Active</x:String>
                <x:String>Inactive</x:String>
            </ComboBox>
            <Button Content="Clear Filters" Command="{x:Bind ViewModel.ClearFiltersCommand}" />
        </StackPanel>

        <Border Grid.Row="2" Margin="0,16,0,0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0">
            <Grid>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <controls:DataGrid x:Name="ProductGrid"
                                   ItemsSource="{x:Bind ViewModel.Products, Mode=OneWay}"
                                   AutoGenerateColumns="False"
                                   CanUserResizeColumns="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="True"
                                   IsReadOnly="True"
                                   SelectionMode="Single"
                                   SelectionChanged="ProductGrid_SelectionChanged"
                                   DoubleTapped="ProductGrid_DoubleTapped"
                                   HeadersVisibility="Column">
                    <controls:DataGrid.Columns>
                        <!-- Columns are built dynamically in code-behind based on visibility preferences -->
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
