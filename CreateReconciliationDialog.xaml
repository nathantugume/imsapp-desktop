<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.CreateReconciliationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="New Stock Reconciliation"
    PrimaryButtonText="Create"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Create_Click"
    DefaultButton="Primary">

    <StackPanel Padding="0,8,0,0">
        <ComboBox x:Name="ProductCombo" Header="Product" DisplayMemberPath="ProductName" Margin="0,0,0,8" />
        <TextBlock x:Name="SystemStockText" Text="System stock: -" Margin="0,0,0,4" />
        <NumberBox x:Name="PhysicalCountBox" Header="Physical Count" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" Margin="0,0,0,8" />
        <TextBox x:Name="NotesBox" Header="Notes (optional)" PlaceholderText="Optional notes" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,0" />
    </StackPanel>
</ContentDialog>
