<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.AddUserDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add User"
    PrimaryButtonText="Create"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Create_Click"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="450">
        <StackPanel Padding="0,8,0,0">
            <TextBox x:Name="NameBox" Header="Full Name" PlaceholderText="Enter full name" Margin="0,0,0,8" />
            <TextBox x:Name="EmailBox" Header="Email Address" PlaceholderText="Enter email" InputScope="EmailSmtpAddress" Margin="0,0,0,8" />
            <PasswordBox x:Name="PasswordBox" Header="Password" PlaceholderText="Min 6 characters" Margin="0,0,0,8" />
            <PasswordBox x:Name="ConfirmPasswordBox" Header="Confirm Password" PlaceholderText="Re-enter password" Margin="0,0,0,8" />
            <TextBox x:Name="CountryBox" Header="Country" PlaceholderText="Enter country" Margin="0,0,0,0" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
