<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:ReportsViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Reports" Style="{StaticResource PageTitleStyle}" />
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
                <Button Content="Export" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Export CSV" Click="ExportCsv_Click" />
                            <MenuFlyoutItem Text="Export Excel" Click="ExportExcel_Click" />
                            <MenuFlyoutItem Text="Export PDF" Click="ExportPdf_Click" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Filters -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ComboBox x:Name="FilterCombo" Header="Period" Width="140" Margin="0,0,12,0" SelectedIndex="0" SelectionChanged="FilterCombo_SelectionChanged">
                    <x:String>daily</x:String>
                    <x:String>monthly</x:String>
                    <x:String>yearly</x:String>
                </ComboBox>
                <DatePicker x:Name="DatePicker" Header="Date" Margin="0,0,12,0" Visibility="Visible" />
                <DatePicker x:Name="MonthPicker" Header="Month" Margin="0,0,12,0" Visibility="Collapsed" />
                <NumberBox x:Name="YearBox" Header="Year" Value="2025" Minimum="2020" Maximum="2030" SpinButtonPlacementMode="Inline" Width="120" Margin="0,0,12,0" Visibility="Collapsed" />
                <Button Content="Apply" Click="ApplyFilter_Click" VerticalAlignment="Bottom" />
            </StackPanel>

            <!-- Report title -->
            <TextBlock Text="{x:Bind ViewModel.ReportTitle, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{x:Bind ViewModel.ReportPeriod, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,16" />

            <!-- Summary cards -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Style="{StaticResource StatCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Orders" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="{x:Bind ViewModel.OrderCount, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Total Sales" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="{x:Bind ViewModel.TotalSalesFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Revenue" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="{x:Bind ViewModel.RevenueFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Profit" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="{x:Bind ViewModel.ProfitFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Orders table -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,0,0,0">
                <controls:DataGrid x:Name="ReportGrid"
                                  ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNo}" Width="80" />
                        <controls:DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                        <controls:DataGridTextColumn Header="Total" Binding="{Binding NetTotalFormatted}" Width="120" />
                        <controls:DataGridTextColumn Header="Paid" Binding="{Binding PaidFormatted}" Width="120" />
                        <controls:DataGridTextColumn Header="Due" Binding="{Binding DueFormatted}" Width="120" />
                        <controls:DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="100" />
                        <controls:DataGridTextColumn Header="Date" Binding="{Binding OrderDate}" Width="100" />
                        <controls:DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="70" />
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
