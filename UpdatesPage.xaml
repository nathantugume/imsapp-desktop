<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" MaxWidth="700">
            <TextBlock Text="Updates" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,8" />
            <TextBlock Text="Check for and install application updates" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="16" Margin="0,0,0,24" />

            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,16">
                <StackPanel Spacing="16">
                    <TextBlock Text="Application Updates" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock x:Name="StatusText" Text="Click 'Check for Updates' to see if a new version is available."
                        TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="CheckButton" Content="Check for Updates" Style="{ThemeResource AccentButtonStyle}" Click="CheckForUpdates_Click" />
                        <Button x:Name="UpdateButton" Content="Install Update" Style="{ThemeResource AccentButtonStyle}" Click="InstallUpdate_Click" Visibility="Collapsed" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
