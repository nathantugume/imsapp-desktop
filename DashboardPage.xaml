<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:svc="using:imsapp_desktop.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:DashboardViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="32" MaxWidth="1400">
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Dashboard" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.WelcomeMessage, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" VerticalAlignment="Center" />
            </Grid>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Left" Margin="0,0,0,16" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Margin="0,0,0,16" />

            <TextBlock Text="Overview" Style="{StaticResource SectionHeaderStyle}" />
            <StackPanel Orientation="Horizontal" Margin="0,-12,0,0">
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Users" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.UserCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Categories" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.CategoryCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Brands" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.BrandCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Products" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.ProductCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Suppliers" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.SupplierCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="110">
                    <StackPanel>
                        <TextBlock Text="Orders" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.OrderCount, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="Orders" Style="{StaticResource SectionHeaderStyle}" />
            <StackPanel Orientation="Horizontal" Margin="0,-12,0,0">
                <Border Style="{StaticResource StatCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Total Value" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.TotalOrderValueFormatted, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Order Count" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.OrderCount, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Cash Received" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.CashReceivedFormatted, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Outstanding" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.OutstandingFormatted, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="Today's Performance" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource StatCardStyle}" MinWidth="200" Margin="0,-12,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Revenue" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.TodayRevenueFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Sales" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.TodaySalesCount, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Cost" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.TodayCostFormatted, Mode=OneWay}" FontSize="14" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Profit" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.TodayProfitFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Profit" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource StatCardStyle}" MinWidth="200" Margin="0,-12,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="This Month Revenue" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MonthlyRevenueFormatted, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="This Month Cost" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MonthlyCostFormatted, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="This Month Profit" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MonthlyProfitFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.ProfitMarginFormatted, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <TextBlock Text="Inventory" Style="{StaticResource SectionHeaderStyle}" />
            <StackPanel Orientation="Horizontal" Margin="0,-12,0,0">
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Inventory Value" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.InventoryValueFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Potential Profit" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.PotentialProfitFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Expiry Warnings" Style="{StaticResource SectionHeaderStyle}" />
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,-12,0,0" MaxHeight="180">
                        <Grid>
                            <ListView ItemsSource="{x:Bind ViewModel.ExpiryWarnings, Mode=OneWay}" Background="Transparent" BorderThickness="0" SelectionMode="None" Visibility="{x:Bind ViewModel.HasNoExpiryWarnings, Mode=OneWay, Converter={StaticResource BoolToCollapsed}}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="svc:ExpiryWarningItem">
                                        <StackPanel Margin="0,4" Orientation="Horizontal">
                                            <TextBlock Text="{x:Bind ProductName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind DaysLeftDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock Text="No products expiring soon" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="13" Visibility="{x:Bind ViewModel.HasNoExpiryWarnings, Mode=OneWay, Converter={StaticResource BoolToVisible}}" />
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Recent Sales" Style="{StaticResource SectionHeaderStyle}" />
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,-12,0,0" MaxHeight="180">
                        <ListView ItemsSource="{x:Bind ViewModel.RecentSales, Mode=OneWay}" Background="Transparent" BorderThickness="0" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="svc:RecentSaleItem">
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{x:Bind CustomerName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ProductName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
