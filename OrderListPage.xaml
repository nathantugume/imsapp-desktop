<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="imsapp_desktop.OrderListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:imsapp_desktop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <vm:OrderListViewModel x:Name="OrderListVM" />
    </Page.DataContext>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Orders" Style="{StaticResource PageTitleStyle}" />
            <Button Content="Refresh" Command="{x:Bind OrderListVM.LoadCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
            <Button Content="Create Order" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" VerticalAlignment="Center" Click="CreateOrder_Click" />
            <Button Content="View" Margin="8,0,0,0" VerticalAlignment="Center" Click="ViewOrder_Click" IsEnabled="{x:Bind OrderListVM.HasSelection, Mode=OneWay}" />
            <Button Content="Print Invoice" Margin="8,0,0,0" VerticalAlignment="Center" Click="PrintInvoice_Click" IsEnabled="{x:Bind OrderListVM.HasSelection, Mode=OneWay}" />
            <Button Content="Export" Margin="8,0,0,0" VerticalAlignment="Center">
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Export CSV" Click="ExportCsv_Click" />
                        <MenuFlyoutItem Text="Export Excel" Click="ExportExcel_Click" />
                        <MenuFlyoutItem Text="Export PDF" Click="ExportPdf_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ProgressRing IsActive="{x:Bind OrderListVM.IsLoading, Mode=OneWay}" />
            <TextBlock Text="{x:Bind OrderListVM.ErrorMessage, Mode=OneWay}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="0">
            <controls:DataGrid x:Name="OrderGrid"
                              ItemsSource="{x:Bind OrderListVM.Orders, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              CanUserReorderColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="OrderGrid_SelectionChanged"
                              HeadersVisibility="Column">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="ID" Binding="{Binding InvoiceNo}" Width="80" />
                    <controls:DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding NetTotalFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Paid" Binding="{Binding PaidFormatted}" Width="120" />
                    <controls:DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="100" />
                    <controls:DataGridTextColumn Header="Date" Binding="{Binding OrderDate}" Width="100" />
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>
    </Grid>
</Page>
