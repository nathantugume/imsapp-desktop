<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="imsapp_desktop.ResetPasswordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Reset Password"
    PrimaryButtonText="Reset"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="Reset_Click"
    DefaultButton="Primary">

    <StackPanel Padding="0,8,0,0">
        <PasswordBox x:Name="OldPasswordBox" Header="Old Password" PlaceholderText="Enter current password" Margin="0,0,0,8" />
        <PasswordBox x:Name="NewPasswordBox" Header="New Password" PlaceholderText="Enter new password (min 6 characters)" Margin="0,0,0,8" />
        <PasswordBox x:Name="ConfirmPasswordBox" Header="Confirm New Password" PlaceholderText="Confirm new password" Margin="0,0,0,0" />
    </StackPanel>
</ContentDialog>
